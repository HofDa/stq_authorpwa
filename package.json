{
  "name": "southtyrolquests-author-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mobile-first PWA for authoring SouthTyrolQuests tours in the field.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
